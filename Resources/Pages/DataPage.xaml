<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:db="clr-namespace:Cash_Tracker.Resources.Database"
             xmlns:pg="clr-namespace:Cash_Tracker.Resources.Pages"
             xmlns:shimmer="clr-namespace:Syncfusion.Maui.Toolkit.Shimmer;assembly=Syncfusion.Maui.Toolkit"
             x:Class="Cash_Tracker.Resources.Pages.DataPage">
    <ScrollView>
        <shimmer:SfShimmer IsActive="True" x:Name="shimer" WaveDirection="Default" BackgroundColor="{StaticResource OffBlack}" Fill="{StaticResource Gray600}" WaveColor="{StaticResource Gray500}">
            <shimmer:SfShimmer.CustomView>
                <StackLayout Spacing="20" Margin="15">
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                    <BoxView BackgroundColor="{StaticResource Gray600}" WidthRequest="370" HeightRequest="110" CornerRadius="15"/>
                </StackLayout>
            </shimmer:SfShimmer.CustomView>
            
            <VerticalStackLayout x:Name="Obsah" IsVisible="False" HorizontalOptions="Center">
                <Button x:Name="btnOdeber" Text="Odebrat záznam" Margin="15" Clicked="btnOdeber_Clicked"/>
                <CollectionView x:Name="CVHistorie" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <StackLayout HorizontalOptions="Center">
                            <Label Text="Ještě jsi neudělal žádný záznam"/>
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="db:DataDB">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 20" HorizontalOptions="Center"  VerticalOptions="Center" BackgroundColor="Transparent" Padding="25" Margin="0, 15">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                                </Border.GestureRecognizers>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Gray400}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Gray600}"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="150, 150" RowDefinitions="25, 25" ColumnSpacing="20" RowSpacing="10" IsClippedToBounds="True">
                                    <Label Text="{Binding Kategorie}" FontAttributes="Bold" FontSize="20" Grid.Column="0" Grid.Row="0"/>

                                    <Label Text="{Binding CastkaSMenou}"  HorizontalOptions="End" FontSize="20" Grid.Column="1" Grid.Row="0" FontAttributes="Bold">

                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Prijem}" Value="True">
                                                <Setter Property="TextColor" Value="Lime"/>
                                            </DataTrigger>

                                            <DataTrigger TargetType="Label" Binding="{Binding Prijem}" Value="False">
                                                <Setter Property="TextColor" Value="Red"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding Datum, StringFormat='{0:dd.MM.yyyy}'}" Grid.Column="0" Grid.Row="1"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </shimmer:SfShimmer>
    </ScrollView>
</ContentPage>